# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
ENV/

# Environment files
.env
.env.*
!.env.example

# Local databases and generated runtime data
candidate_screening.db
*.db
*.sqlite
*.sqlite3

# Chroma / vector store persistence
chroma_db/
chromadb/
chroma.sqlite3

# Uploaded files / runtime artifacts
data/uploads/
data/tmp/
tmp/
temp/

# Knowledge base runtime files if they are local-only or regenerated
data/knowledge_base/**/*.pdf
data/knowledge_base/**/*.txt
data/knowledge_base/**/*.docx

# Test and lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Packaging / build
build/
dist/
*.egg-info/
.eggs/

# Jupyter
.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db

# IDE/editor
.vscode/
.idea/

# Logs
*.log

# Alembic / migrations cache if generated locally
app/db/migrations/__pycache__/